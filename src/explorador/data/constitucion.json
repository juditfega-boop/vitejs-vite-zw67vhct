          {
            "id": "articulo-1", "label": "Artículo 1",
            "resumen": "España se constituye en Estado social y democrático de Derecho",
            "contenido": "España se constituye en un Estado social y democrático de Derecho, que propugna como valores superiores de su ordenamiento jurídico la libertad, la justicia, la igualdad y el pluralismo político.",
            "destacado": true, "children": []
          },
          { "id": "articulo-2", "label": "Artículo 2", "resumen": "Unidad de la Nación y autonomía de nacionalidades y regiones", "contenido": "La Constitución se fundamenta en la unidad indisoluble de la Nación española, patria común e indivisible de todos los españoles.", "children": [] },
          { "id": "articulo-3", "label": "Artículo 3", "resumen": "El castellano y las demás lenguas oficiales", "contenido": "El castellano es la lengua española oficial del Estado. Las demás lenguas españolas serán también oficiales en las respectivas Comunidades Autónomas de acuerdo con sus Estatutos.", "children": [] },
          { "id": "articulo-4", "label": "Artículo 4", "resumen": "La bandera de España", "contenido": "La bandera de España está formada por tres bandas horizontales, roja, amarilla y roja, siendo la amarilla de doble anchura que cada una de las rojas.", "children": [] },
          { "id": "articulo-5", "label": "Artículo 5", "resumen": "La capital del Estado", "contenido": "La capital del Estado es la villa de Madrid. El Estado podrá trasladar su sede a otra localidad dentro del territorio español.", "children": [] },
          { "id": "articulo-6", "label": "Artículo 6", "resumen": "Los partidos políticos", "contenido": "Los partidos políticos expresan el pluralismo político, concurren a la formación y manifestación de la voluntad popular y son instrumento fundamental para la participación política.", "children": [] },
          { "id": "articulo-7", "label": "Artículo 7", "resumen": "PENDIENTE: rellenar", "contenido": "PENDIENTE: rellenar", "children": [] },
          { "id": "articulo-8", "label": "Artículo 8", "resumen": "Las Fuerzas Armadas", "contenido": "Las Fuerzas Armadas garantizan la soberanía e independencia de España, defienden su integridad territorial y el ordenamiento constitucional.", "children": [] },
          {
            "id": "articulo-9", "label": "Artículo 9",
            "resumen": "Sujeción a la Constitución y promoción de la igualdad real",
            "contenido": "Los ciudadanos y los poderes públicos están sujetos a la Constitución y al resto del ordenamiento jurídico. Promueven las condiciones para que la libertad y la igualdad del individuo y de los grupos en que se integra sean reales y efectivas.",
            "destacado": true, "children": []
          }
        ]
